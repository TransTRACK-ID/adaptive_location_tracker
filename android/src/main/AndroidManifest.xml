<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Also required in the host app's own manifest / build for a runtime
         prompt: ACCESS_FINE_LOCATION, ACCESS_BACKGROUND_LOCATION. Declared
         here too so the merged manifest is complete without the host app
         needing to duplicate them, but the runtime permission *request*
         flow is still the host app's responsibility (see MIGRATION.md). -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application>
        <service
            android:name="dev.adaptive_location_tracker.LocationTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <receiver
            android:name="dev.adaptive_location_tracker.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
